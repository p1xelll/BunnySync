# BunnySync Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Server bind address (required)
BIND_ADDR=0.0.0.0:3000

# Global BunnyCDN API Key for cache purging (required)
# Get this from: BunnyCDN Dashboard → Account → API Key
BUNNY_API_KEY=your-global-bunny-api-key-here

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================
# Replace PROJECT_ID with your project identifier (uppercase, e.g., MYAPP, BLOG)
# You can configure multiple projects by adding more PROJECT_* variables

# -----------------------------------------------------------------------------
# Example Project: MYAPP
# -----------------------------------------------------------------------------

# Git repository URL (HTTPS only)
PROJECT_MYAPP_REPO_URL=https://git.example.com/username/myapp.git

# Webhook secret (min 32 characters, must match webhook configuration)
# Generate with: openssl rand -base64 32
PROJECT_MYAPP_WEBHOOK_SECRET=generate-a-random-secret-min-32-characters-long

# Bunny Storage Zone name
PROJECT_MYAPP_BUNNY_STORAGE_ZONE=myapp-storage-zone

# Bunny Storage Zone password (NOT API key)
# Get this from: BunnyCDN Dashboard → Storage → [Your Zone] → FTP & API Access
PROJECT_MYAPP_BUNNY_STORAGE_PASSWORD=your-storage-zone-password-here

# Bunny Pull Zone ID (numeric)
# Get this from: BunnyCDN Dashboard → Pull Zones → [Your Zone] → ID column
PROJECT_MYAPP_BUNNY_PULL_ZONE_ID=123456

# Bunny Pull Zone domain (without protocol)
PROJECT_MYAPP_BUNNY_PULL_ZONE_DOMAIN=cdn.example.com

# Optional: Project-specific Bunny API key (overrides global BUNNY_API_KEY)
# PROJECT_MYAPP_BUNNY_API_KEY=optional-project-specific-api-key

# -----------------------------------------------------------------------------
# Example Project: WEBSITE (uncomment to use)
# -----------------------------------------------------------------------------

# PROJECT_WEBSITE_REPO_URL=https://git.example.com/username/website.git
# PROJECT_WEBSITE_WEBHOOK_SECRET=another-random-secret-min-32-characters-long
# PROJECT_WEBSITE_BUNNY_STORAGE_ZONE=website-storage-zone
# PROJECT_WEBSITE_BUNNY_STORAGE_PASSWORD=website-storage-password
# PROJECT_WEBSITE_BUNNY_PULL_ZONE_ID=789012
# PROJECT_WEBSITE_BUNNY_PULL_ZONE_DOMAIN=www.example.com

# -----------------------------------------------------------------------------
# Example Project: BLOG (uncomment to use)
# -----------------------------------------------------------------------------

# PROJECT_BLOG_REPO_URL=https://git.example.com/username/blog.git
# PROJECT_BLOG_WEBHOOK_SECRET=yet-another-random-secret-min-32-characters
# PROJECT_BLOG_BUNNY_STORAGE_ZONE=blog-storage-zone
# PROJECT_BLOG_BUNNY_STORAGE_PASSWORD=blog-storage-password
# PROJECT_BLOG_BUNNY_PULL_ZONE_ID=345678
# PROJECT_BLOG_BUNNY_PULL_ZONE_DOMAIN=blog.example.com
